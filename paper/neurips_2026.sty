% neurips_2026.sty — NeurIPS 2026 submission/camera-ready style
% Based on the official NeurIPS formatting guidelines.
%
% Options:
%   [final]     — camera-ready version (shows authors, no anonymity notice)
%   [preprint]  — preprint version (shows authors + "Preprint" notice)
%   (default)   — anonymous submission (hides authors, shows submission notice)
%   [nonatbib]  — do not load natbib (if you load it yourself)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/15 NeurIPS 2026 submission style]

% ---------- Option handling ----------
\newif\if@preprint\@preprintfalse
\newif\if@final\@finalfalse
\newif\if@nonatbib\@nonatbibfalse
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% ---------- Fonts ----------
\RequirePackage{times}
\RequirePackage{latexsym}

% ---------- Page geometry (NeurIPS standard) ----------
% 5.5in x 9in text block on US letter, 1in top margin
\RequirePackage[letterpaper,
  textwidth=5.5in,
  textheight=9in,
  top=1in,
  headheight=14pt]{geometry}

% ---------- Paragraph formatting ----------
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

% ---------- Line spacing ----------
\RequirePackage{setspace}
\setstretch{1.0}

% ---------- Section formatting ----------
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{2.0ex plus 1ex minus .2ex}{1.0ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 1ex minus .2ex}{0.8ex plus .2ex}
\titlespacing*{\subsubsection}{0pt}{1.0ex plus 0.5ex minus .2ex}{0.5ex plus .2ex}

% ---------- Footnote rule ----------
\renewcommand\footnoterule{%
  \kern-3\p@
  \hrule\@width 2in
  \kern 2.6\p@}

% ---------- Title / author block ----------
\def\@maketitle{%
  \newpage
  \null
  \vskip 0.1in
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.2in
    \if@final
      % Camera-ready: show real authors
      {\normalsize
       \begin{tabular}[t]{c}%
         \@author
       \end{tabular}\par}%
    \else\if@preprint
      % Preprint: show real authors + preprint notice
      {\normalsize
       \begin{tabular}[t]{c}%
         \@author
       \end{tabular}\par}%
      \vskip 0.1in
      {\small Preprint. Under review.\par}%
    \else
      % Anonymous submission
      {\normalsize Anonymous Author(s)\par}%
      {\small Submitted to NeurIPS 2026. Do not distribute.\par}%
    \fi\fi
    \vskip 0.3in
  \end{center}}

% ---------- Abstract ----------
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small}%
  {\end{quote}\vspace{1ex}}

% ---------- Headers / footers ----------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\if@final
  \fancyfoot[C]{\thepage}
\else\if@preprint
  \fancyfoot[C]{\small Preprint \hfill \thepage}
\else
  \fancyfoot[C]{\small Submitted to NeurIPS 2026 \hfill \thepage}
\fi\fi

% ---------- Bibliography ----------
\if@nonatbib\else
  \RequirePackage[round,sort&compress,numbers]{natbib}
  \bibliographystyle{plainnat}
\fi

% ---------- Hyperref ----------
\RequirePackage[colorlinks,
  citecolor=blue,
  urlcolor=blue,
  linkcolor=blue,
  bookmarks=false]{hyperref}

% ---------- Graphics ----------
\RequirePackage{graphicx}

% ---------- Math ----------
\RequirePackage{amsmath,amsfonts,amssymb}

% ---------- Tables ----------
\RequirePackage{booktabs}

% ---------- Microtype (improved typography) ----------
\RequirePackage{microtype}

\endinput
